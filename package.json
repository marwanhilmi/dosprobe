    "@typescript/native-preview": "7.0.0-dev.20260310.1",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^6.0.1-rc",
    "vitest": "^4"
  }
